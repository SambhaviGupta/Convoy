# Copy this file to .env and fill in your real Neon connection string
# Get it from https://console.neon.tech -> your project -> Connection string
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxxx-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Any random long string works for local/hackathon use
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
